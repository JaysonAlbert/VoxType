{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxType",
  "version": "0.1.0",
  "identifier": "com.voxtype.app",
  "package": {
    "productName": "VoxType",
    "version": "0.1.0"
  },
  "app": {
    "windows": [
      {
        "title": "VoxType",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/icon.ico"
    ]
  }
}
